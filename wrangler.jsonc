{
         "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "portfolio",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}